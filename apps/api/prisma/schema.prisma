// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ---------- enums ----------

// Global identity role, held once per User — drives which linked profile
// (Seller? / CarrierUser?) exists and what the JWT/RolesGuard checks.
enum GlobalRole {
  ADMIN
  SELLER
  CARRIER_MANAGER
  CARRIER_OPERATOR
}

// Role scoped to a single CarrierUser within one Carrier — kept separate from
// GlobalRole so an invalid combination (e.g. a CarrierUser typed ADMIN) is a
// compile-time impossibility, not just an app-level convention. See DESIGN.md.
enum CarrierRole {
  MANAGER
  OPERATOR
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum ShipmentStatus {
  PENDING // created, no owner, in the carrier's queue
  ACCEPTED // an operator claimed it
  COLLECTED // picked up from the seller
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED_DELIVERY
  CANCELLED // only possible before COLLECTED
  RETURNED // exception path after FAILED_DELIVERY
}

// ---------- auth ----------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         GlobalRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  seller      Seller?
  carrierUser CarrierUser?
}

// ---------- seller ----------

model Seller {
  id          String         @id @default(uuid())
  userId      String         @unique
  user        User           @relation(fields: [userId], references: [id])
  companyName String
  document    String         @unique
  status      ApprovalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  shipments         Shipment[]
  enabledModalities SellerModality[]

  // Serves GET /sellers?status= (the admin's default "queue" view, §16.1)
  @@index([status])
}

// ---------- carrier ----------

model Carrier {
  id          String         @id @default(uuid())
  companyName String
  document    String         @unique
  status      ApprovalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  users         CarrierUser[]
  invites       Invite[]
  coverageAreas CarrierCoverageArea[]
  modalities    CarrierModality[]
  shipments     Shipment[]

  // Serves GET /carriers?status= (§17), same reasoning as Seller.status
  @@index([status])
}

model CarrierUser {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  carrierId String
  carrier   Carrier  @relation(fields: [carrierId], references: [id])
  role      CarrierRole
  createdAt DateTime @default(now())

  ownedShipments Shipment[] @relation("ShipmentOwner")

  // Prisma doesn't auto-index plain FK scalar columns on Postgres — this
  // composite matches the exact shape of every carriers.service.ts query
  // (`where: { carrierId, role: MANAGER }`, run on every list/detail/approve/
  // reject call), not just a generic "there's a where clause" guess.
  @@index([carrierId, role])
}

model Invite {
  id        String       @id @default(uuid())
  token     String       @unique
  email     String
  carrierId String
  carrier   Carrier      @relation(fields: [carrierId], references: [id])
  status    InviteStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime     @default(now())

  // Anticipates Operator Management (SCREENS.md) — list invites for one
  // carrier, expired ones shown distinctly rather than filtered out. `token`
  // already has its own index via @unique for the accept-flow lookup.
  @@index([carrierId, status])
}

model CarrierCoverageArea {
  id        String   @id @default(uuid())
  carrierId String
  carrier   Carrier  @relation(fields: [carrierId], references: [id])
  state     String
  city      String? // null = covers the entire state
  createdAt DateTime @default(now())

  @@unique([carrierId, state, city])
  // The unique constraint above only serves lookups that start with
  // `carrierId` (leftmost-prefix rule) — but the actual hot-path query at
  // shipment-creation time (DESIGN.md § 10) runs in the OPPOSITE direction:
  // "given this address's state/city, which carriers cover it?" `carrierId`
  // isn't known yet, it's what we're solving for. Without this index, that
  // query would sequential-scan the whole table on every shipment created.
  @@index([state, city])
}

// ---------- delivery modality ----------

model DeliveryModality {
  id        String   @id @default(uuid())
  code      String   @unique // "STANDARD", "FULL", "EXPRESS"
  name      String
  slaHours  Int? // used by the future SLA-breach alert
  createdAt DateTime @default(now())

  carrierModalities CarrierModality[]
  sellerModalities  SellerModality[]
  shipments         Shipment[]
}

model CarrierModality {
  id         String           @id @default(uuid())
  carrierId  String
  carrier    Carrier          @relation(fields: [carrierId], references: [id])
  modalityId String
  modality   DeliveryModality @relation(fields: [modalityId], references: [id])
  createdAt  DateTime         @default(now())

  @@unique([carrierId, modalityId])
  // Same leftmost-prefix reasoning as CarrierCoverageArea: the unique
  // constraint serves "modalities for carrier X", but shipment creation also
  // needs the reverse — "carriers offering modality Y" — as part of the same
  // coverage+modality+status filter. SellerModality doesn't get an
  // equivalent index: there's no documented "sellers using modality Y" query,
  // and indexing without a real access pattern is its own anti-pattern.
  @@index([modalityId])
}

model SellerModality {
  id         String           @id @default(uuid())
  sellerId   String
  seller     Seller           @relation(fields: [sellerId], references: [id])
  modalityId String
  modality   DeliveryModality @relation(fields: [modalityId], references: [id])
  createdAt  DateTime         @default(now())

  @@unique([sellerId, modalityId])
}

// ---------- shipment ----------

model Shipment {
  id           String           @id @default(uuid())
  trackingCode String           @unique
  sellerId     String
  seller       Seller           @relation(fields: [sellerId], references: [id])
  carrierId    String
  carrier      Carrier          @relation(fields: [carrierId], references: [id])
  modalityId   String
  modality     DeliveryModality @relation(fields: [modalityId], references: [id])
  ownerId      String?
  owner        CarrierUser?     @relation("ShipmentOwner", fields: [ownerId], references: [id])
  status       ShipmentStatus   @default(PENDING)

  addressStreet       String
  addressNumber       String
  addressComplement   String?
  addressNeighborhood String
  addressCity         String
  addressState        String
  addressZipCode      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trackingEvents TrackingEvent[]

  // Seller's Shipments List (own shipments, optionally by status) and the
  // Carrier's shared queue (assigned shipments, optionally by status) are
  // the two highest-traffic reads in the whole product — this is the table
  // DESIGN.md § 12's performance guidance already singled out by name.
  @@index([sellerId, status])
  @@index([carrierId, status])
  // "No owner yet" (claim eligibility) and "shipments I own" both filter on
  // this column directly; nullable FKs still benefit from an index in
  // Postgres (a partial index on `ownerId IS NULL` would be even more
  // targeted, but isn't worth the extra migration complexity yet).
  @@index([ownerId])
}

model TrackingEvent {
  id         String         @id @default(uuid())
  shipmentId String
  shipment   Shipment       @relation(fields: [shipmentId], references: [id])
  status     ShipmentStatus
  note       String?
  createdAt  DateTime       @default(now()) // immutable — never has an updatedAt

  // Composite, not just `[shipmentId]` — Shipment Detail always reads one
  // shipment's full timeline pre-sorted by time; this index serves the
  // filter AND the sort order in one pass, no separate sort step needed.
  @@index([shipmentId, createdAt])
}
