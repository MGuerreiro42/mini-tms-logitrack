// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ---------- enums ----------

// Global identity role, held once per User — drives which linked profile
// (Seller? / CarrierUser?) exists and what the JWT/RolesGuard checks.
enum GlobalRole {
  ADMIN
  SELLER
  CARRIER_MANAGER
  CARRIER_OPERATOR
}

// Role scoped to a single CarrierUser within one Carrier — kept separate from
// GlobalRole so an invalid combination (e.g. a CarrierUser typed ADMIN) is a
// compile-time impossibility, not just an app-level convention. See DESIGN.md.
enum CarrierRole {
  MANAGER
  OPERATOR
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum ShipmentStatus {
  PENDING // created, no owner, in the carrier's queue
  ACCEPTED // an operator claimed it
  COLLECTED // picked up from the seller
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED_DELIVERY
  CANCELLED // only possible before COLLECTED
  RETURNED // exception path after FAILED_DELIVERY
}

// ---------- auth ----------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         GlobalRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  seller      Seller?
  carrierUser CarrierUser?
}

// ---------- seller ----------

model Seller {
  id          String         @id @default(uuid())
  userId      String         @unique
  user        User           @relation(fields: [userId], references: [id])
  companyName String
  document    String         @unique
  status      ApprovalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  shipments         Shipment[]
  enabledModalities SellerModality[]
}

// ---------- carrier ----------

model Carrier {
  id          String         @id @default(uuid())
  companyName String
  document    String         @unique
  status      ApprovalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  users         CarrierUser[]
  invites       Invite[]
  coverageAreas CarrierCoverageArea[]
  modalities    CarrierModality[]
  shipments     Shipment[]
}

model CarrierUser {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  carrierId String
  carrier   Carrier  @relation(fields: [carrierId], references: [id])
  role      CarrierRole
  createdAt DateTime @default(now())

  ownedShipments Shipment[] @relation("ShipmentOwner")
}

model Invite {
  id        String       @id @default(uuid())
  token     String       @unique
  email     String
  carrierId String
  carrier   Carrier      @relation(fields: [carrierId], references: [id])
  status    InviteStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime     @default(now())
}

model CarrierCoverageArea {
  id        String   @id @default(uuid())
  carrierId String
  carrier   Carrier  @relation(fields: [carrierId], references: [id])
  state     String
  city      String? // null = covers the entire state
  createdAt DateTime @default(now())

  @@unique([carrierId, state, city])
}

// ---------- delivery modality ----------

model DeliveryModality {
  id        String   @id @default(uuid())
  code      String   @unique // "STANDARD", "FULL", "EXPRESS"
  name      String
  slaHours  Int? // used by the future SLA-breach alert
  createdAt DateTime @default(now())

  carrierModalities CarrierModality[]
  sellerModalities  SellerModality[]
  shipments         Shipment[]
}

model CarrierModality {
  id         String           @id @default(uuid())
  carrierId  String
  carrier    Carrier          @relation(fields: [carrierId], references: [id])
  modalityId String
  modality   DeliveryModality @relation(fields: [modalityId], references: [id])
  createdAt  DateTime         @default(now())

  @@unique([carrierId, modalityId])
}

model SellerModality {
  id         String           @id @default(uuid())
  sellerId   String
  seller     Seller           @relation(fields: [sellerId], references: [id])
  modalityId String
  modality   DeliveryModality @relation(fields: [modalityId], references: [id])
  createdAt  DateTime         @default(now())

  @@unique([sellerId, modalityId])
}

// ---------- shipment ----------

model Shipment {
  id           String           @id @default(uuid())
  trackingCode String           @unique
  sellerId     String
  seller       Seller           @relation(fields: [sellerId], references: [id])
  carrierId    String
  carrier      Carrier          @relation(fields: [carrierId], references: [id])
  modalityId   String
  modality     DeliveryModality @relation(fields: [modalityId], references: [id])
  ownerId      String?
  owner        CarrierUser?     @relation("ShipmentOwner", fields: [ownerId], references: [id])
  status       ShipmentStatus   @default(PENDING)

  addressStreet       String
  addressNumber       String
  addressComplement   String?
  addressNeighborhood String
  addressCity         String
  addressState        String
  addressZipCode      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trackingEvents TrackingEvent[]
}

model TrackingEvent {
  id         String         @id @default(uuid())
  shipmentId String
  shipment   Shipment       @relation(fields: [shipmentId], references: [id])
  status     ShipmentStatus
  note       String?
  createdAt  DateTime       @default(now()) // immutable — never has an updatedAt
}
