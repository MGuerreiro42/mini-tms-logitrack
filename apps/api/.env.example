# Copie para .env e ajuste se necessário. Valores abaixo já batem com o docker-compose.yml da raiz.

DATABASE_URL="postgresql://tms:tms@localhost:5432/tms?schema=public"

# Next.js dev server já usa a 3000 por padrão — API roda em porta separada
PORT=3333

# Gere um valor novo por ambiente, nunca reaproveite entre dev/staging/prod:
#   openssl rand -hex 32
JWT_SECRET="troque-por-um-valor-gerado-com-openssl-rand--hex-32"

# origem permitida pro CORS — Next.js roda em localhost:3000
CORS_ORIGIN="http://localhost:3000"

# Opcional — usados só pelo `prisma db seed` (prisma/seed.ts). Sem eles, usa os defaults abaixo.
ADMIN_EMAIL="admin@minitms.dev"
ADMIN_PASSWORD="admin12345"
