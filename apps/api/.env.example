# Copy to .env and adjust if needed. Values below already match the root docker-compose.yml.

DATABASE_URL="postgresql://tms:tms@localhost:5432/tms?schema=public"

# Next.js dev server already uses 3000 by default — API runs on a separate port
PORT=3333

# Generate a fresh value per environment, never reuse between dev/staging/prod:
#   openssl rand -hex 32
JWT_SECRET="replace-with-a-value-generated-by-openssl-rand--hex-32"

# origin allowed for CORS — Next.js runs on localhost:3000
CORS_ORIGIN="http://localhost:3000"

# Optional — only used by `prisma db seed` (prisma/seed.ts). Without them, uses the defaults below.
ADMIN_EMAIL="admin@minitms.dev"
ADMIN_PASSWORD="admin12345"
